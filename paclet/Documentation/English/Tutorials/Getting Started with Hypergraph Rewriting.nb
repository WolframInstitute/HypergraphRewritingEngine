Notebook[{

Cell[CellGroupData[{
Cell["Getting Started with Hypergraph Rewriting", "Title",
 CellID->509267359,ExpressionUUID->"4ddb5767-1f00-4973-a411-49eacd07850d"],

Cell["\<\
This tutorial walks through the core workflow: define a rule, evolve a \
hypergraph in all possible ways, and inspect the resulting states, causal, \
and branchial structure.\
\>", "Text",ExpressionUUID->"a4deaa03-819e-bd41-9ccb-9ab062ee38ee"],

Cell["A first evolution", "Section",ExpressionUUID->"52d512ee-9141-964f-a7d5-032d759132c4"],

Cell[TextData[{
 "A rewrite rule is written ",
 Cell[BoxData[
  RowBox[{"lhs", " ", "->", " ", "rhs"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "892cbc4f-349f-594e-8ada-c2e4bf4f916a"],
 ". Each side is a list of hyperedges, and each hyperedge is a list of \
vertices. This rule matches two edges that share a vertex and adds the edge \
closing the triangle between their other two endpoints:"
}], "Text",ExpressionUUID->"72d24395-fae1-194a-8c1c-a9bd7c2d4f23"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}]}], "}"}], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "3"}], "}"}]}], "}"}], ",", " ", "3"}], 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"a574e13c-1334-9a4c-a49a-a3e1fd35e45f"],

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "3"}], "}"}]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "3"}], "}"}]}], "}"}], ",", "3"}], "]"}]], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"0e2ff212-93e7-1c41-a40c-dc0c08615fb8"]
}, Open  ]],

Cell[TextData[{
 "The second argument is the initial state (a list of hyperedges); the third \
is the number of steps. By default ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa7324dc-4d7b-6b49-a77a-b32c2b832784"],
 " returns the combined evolution/causal/branchial graph."
}], "Text",ExpressionUUID->"26abaeba-d6a3-a848-baae-ed5837cdccb0"],

Cell["Choosing what to return", "Section",ExpressionUUID->"9d3da671-730a-124a-85ee-03d86ce1aded"],

Cell["\<\
Pass a property string as the fourth argument to select the output:\
\>", "Text",ExpressionUUID->"a940cb7c-e522-5842-923a-029004ea3c02"],

