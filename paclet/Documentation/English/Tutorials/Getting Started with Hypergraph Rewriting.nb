}, Open  ]],

Cell[TextData[{
 Cell[BoxData["Automatic"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95f33214-812f-a242-a814-03739db473c4"],
 " uses a faster content hash (which may merge some non-isomorphic states); \
",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93fbb855-2487-7d44-87e9-b0e6a86bd485"],
 " is exact."
}], "Text",ExpressionUUID->"b990141a-d365-1e41-bf48-04b1d4af1a89"],

