    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], "}"}], ",", " ", "4", ",", 
   " ", "\"\<NumStates\>\"", ",", " ", 
   RowBox[{"\"\<CanonicalizeStates\>\"", " ", "->", " ", "Full"}]}], 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"0fc62f28-7a31-a145-aac5-343211428361"],

