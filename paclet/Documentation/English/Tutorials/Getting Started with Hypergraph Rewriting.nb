Cell["Higher-arity hyperedges", "Section",ExpressionUUID->"d9f8b38c-76aa-a24d-b6ef-0c7e6ffecbc4"],

Cell["\<\
Edges may have any arity. This rule acts on ternary (3-vertex) hyperedges, \
extending a chain:\
\>", "Text",ExpressionUUID->"15500f2d-4915-084a-a58e-b67f3135cbed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
