Cell["Identifying isomorphic states", "Section",ExpressionUUID->"65546cef-1ff2-b441-bad1-767d9f2eaa52"],

Cell[TextData[{
 "By default every distinct provenance is a separate state. Set ",
 Cell[BoxData["\"\<CanonicalizeStates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4187bed-0a13-5a4a-bec6-ec47c50dea65"],
 " to ",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20b8a957-1dbc-a242-b4fe-f088fd5cd84b"],
 " to identify states that are the same up to isomorphism, collapsing the \
multiway graph:"
}], "Text",ExpressionUUID->"2fd49b8f-12ae-7a4b-9ddd-cd5567accec8"],

