Cell["Identifying isomorphic states", "Section",ExpressionUUID->"b113ce09-fe2a-3b44-bf2d-bab4847c882f"],

Cell[TextData[{
 "By default every distinct provenance is a separate state. Set ",
 Cell[BoxData["\"\<CanonicalizeStates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e646a342-9ee3-1946-87b3-6b2ed3e23b38"],
 " to ",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58ee88d3-14ed-b542-b9d7-5f7e212b3921"],
 " to identify states that are the same up to isomorphism, collapsing the \
multiway graph:"
}], "Text",ExpressionUUID->"cee7842a-496a-f948-84cb-fe62a3d8323c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
