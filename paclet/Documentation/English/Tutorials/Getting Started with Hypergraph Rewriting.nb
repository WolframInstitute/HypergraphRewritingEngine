Notebook[{

Cell[CellGroupData[{
Cell["Getting Started with Hypergraph Rewriting", "Title",
 CellID->509267359,ExpressionUUID->"4ddb5767-1f00-4973-a411-49eacd07850d"],

Cell["\<\
This tutorial walks through the core workflow: define a rule, evolve a \
hypergraph in all possible ways, and inspect the resulting states, causal, \
and branchial structure.\
\>", "Text",ExpressionUUID->"58f261dd-b773-3b41-bb70-2874fb15d561"],

Cell["A first evolution", "Section",ExpressionUUID->"76be58a3-37a6-8b44-bf96-b243aaf9d09a"],

Cell[TextData[{
 "A rewrite rule is written ",
 Cell[BoxData[
  RowBox[{"lhs", " ", "->", " ", "rhs"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6093b3dd-3611-4f4e-924e-9b537981e21c"],
 ". Each side is a list of hyperedges, and each hyperedge is a list of \
vertices. This rule rewrites a single edge into two:"
}], "Text",ExpressionUUID->"a80c539d-0627-884b-9395-77ce81b03395"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}], "}"}], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], "}"}], ",", " ", "4"}], 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"6dd0d050-7102-2b4f-99ba-d1bec98e0f13"],

Cell[BoxData[
 RowBox[{"HGEvolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], "}"}], ",", "4"}], "]"}]], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"ff3cc8e3-92e3-264e-b19b-14d8a9a3269d"]
}, Open  ]],

Cell[TextData[{
 "The second argument is the initial state (a list of hyperedges); the third \
is the number of steps. By default ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9127287e-47a6-7f48-93d5-dce9a68541da"],
 " returns the combined evolution/causal/branchial graph."
}], "Text",ExpressionUUID->"2d1f7701-aecb-5b47-9a64-6fa1e3b78048"],

Cell["Choosing what to return", "Section",ExpressionUUID->"a5ec7e0a-08ad-6d4e-afcf-b3768b84ec0d"],

Cell["\<\
Pass a property string as the fourth argument to select the output:\
\>", "Text",ExpressionUUID->"cb703e2a-55ec-8c43-84eb-add645ec35e6"],

