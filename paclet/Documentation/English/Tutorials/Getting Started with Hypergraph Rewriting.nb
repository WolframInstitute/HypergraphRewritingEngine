 "Where a GPU build is bundled, evolve on the GPU with ",
 Cell[BoxData[
  RowBox[{"\"\<TargetDevice\>\"", " ", "->", " ", "\"\<GPU\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb071ab6-63ca-4748-aeb5-bd5491dcb37e"],
 " (it falls back to the CPU with a message if no GPU binary is present):"
}], "Text",ExpressionUUID->"1772a7f0-613a-224d-8e98-c73754a37a02"],

