Notebook[{

Cell[CellGroupData[{
Cell["HGHausdorffAnalysis", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5574fc78-4ade-0b41-9eb5-153720b25d90"],
 Cell[BoxData[
  RowBox[{"HGHausdorffAnalysis", "[", 
   StyleBox["edges", "TI"], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4e5be3c-344c-9c48-8ff3-156925f76894"],
 "\[LineSeparator]",
 "computes the local Hausdorff dimension at each vertex of the hypergraph ",
 Cell[BoxData["edges"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2da96ce3-5113-f243-8f92-0d68c7984046"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"90aaaade-700b-0d41-8acd-1ba2aa7edc86"],

Cell[TextData[{
 Cell[BoxData["edges"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1b7ef93-5e74-7843-aa98-97227d78f51b"],
 " is a list of hyperedges. The result gives a dimension estimate per vertex \
from ball-growth around it."
}], "Notes",ExpressionUUID->"ab55b48b-ac62-234e-8f93-a8cf17c9fc7b"],

Cell[TextData[{
 "See ",
 Cell[BoxData[
  RowBox[{"Options", "[", "HGHausdorffAnalysis", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f3fe30a2-f3f2-8c48-b8e2-b5dd5a0b5087"],
 " for the analysis and styling options."
}], "Notes",ExpressionUUID->"97cdf909-c1f5-2744-b972-51a837aca2f9"]
}, Open  ]],

