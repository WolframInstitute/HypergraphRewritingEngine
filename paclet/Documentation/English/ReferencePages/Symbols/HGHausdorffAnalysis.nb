Notebook[{

Cell[CellGroupData[{
Cell["HGHausdorffAnalysis", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"bdab00e1-a5d2-654d-82c5-b17964b31666"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["HGHausdorffAnalysis"]], 
     "paclet:WolframInstitute/HypergraphRewriteEngine/ref/\
HGHausdorffAnalysis", 
     "WolframInstitute/HypergraphRewriteEngine Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["edges", "TI"], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "826acec3-d99e-1041-bdea-0ae43b7eddc0"],
 "\[LineSeparator]",
 "computes the local Hausdorff dimension at each vertex of the hypergraph ",
 Cell[BoxData["edges"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1779f1b8-4128-f346-831a-652e7d45e0e5"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"308d8337-0d3e-854f-83c1-eea8d4093318"],

Cell[TextData[{
 Cell[BoxData["edges"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "382014ea-5acf-6640-8c4d-035b20458164"],
 " is a list of hyperedges. The result gives a dimension estimate per vertex \
from ball-growth around it."
}], "Notes",ExpressionUUID->"94e22e20-625c-af45-86b5-f7cf840481c0"],

Cell[TextData[{
 "See ",
 Cell[BoxData[
  RowBox[{"Options", "[", "HGHausdorffAnalysis", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de1f7f34-f75d-a344-8c74-a43876f65495"],
 " for the analysis and styling options."
}], "Notes",ExpressionUUID->"6370b4c2-c90c-7c49-81ca-293a8eb1860b"]
}, Open  ]],

