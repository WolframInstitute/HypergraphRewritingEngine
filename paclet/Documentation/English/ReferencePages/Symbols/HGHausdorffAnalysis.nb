Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HGHausdorffAnalysis", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "3"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"3", ",", " ", "4"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"4", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "3"}], "}"}]}], "}"}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"bf37e9ca-6848-e64b-95b3-2761fb47111e"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"PerVertex\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", "\[RightAssociation]"}]}], ",", 
   RowBox[{"\<\"GeodesicCoords\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", 
     RowBox[{
      RowBox[{"4", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "1", ",", "0"}], "}"}]}], ",", 
      RowBox[{"3", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "1", ",", "0", ",", "1"}], "}"}]}], ",", 
      RowBox[{"2", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "0", ",", "1", ",", "2"}], "}"}]}], ",", 
      RowBox[{"1", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "1", ",", "1"}], "}"}]}]}], 
     "\[RightAssociation]"}]}], ",", 
   RowBox[{"\<\"Anchors\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], ",", 
   RowBox[{"\<\"Stats\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", 
     RowBox[{
      RowBox[{"\<\"Mean\"\>", "\[Rule]", "0.`"}], ",", 
      RowBox[{"\<\"Min\"\>", "\[Rule]", "0.`"}], ",", 
      RowBox[{"\<\"Max\"\>", "\[Rule]", "0.`"}], ",", 
      RowBox[{"\<\"Variance\"\>", "\[Rule]", "0.`"}], ",", 
      RowBox[{"\<\"StdDev\"\>", "\[Rule]", "0.`"}], ",", 
      RowBox[{"\<\"Count\"\>", "\[Rule]", "0"}]}], "\[RightAssociation]"}]}], 
   ",", 
   RowBox[{"\<\"Config\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", 
     RowBox[{
      RowBox[{"\<\"Formula\"\>", "\[Rule]", "\<\"LinearRegression\"\>"}], ",", 
      RowBox[{"\<\"SaturationThreshold\"\>", "\[Rule]", "0.5`"}], ",", 
      RowBox[{"\<\"MinRadius\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"MaxRadius\"\>", "\[Rule]", "5"}], ",", 
      RowBox[{"\<\"NumAnchors\"\>", "\[Rule]", "6"}], ",", 
      RowBox[{"\<\"AnchorSeparation\"\>", "\[Rule]", "3"}]}], 
     "\[RightAssociation]"}]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"8dc6ce05-e657-864d-8bb9-bae682630c96"]
}, Open  ]]
}, Open  ]],

