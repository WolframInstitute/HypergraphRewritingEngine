Notebook[{

Cell[CellGroupData[{
Cell["HGBrillLindquist", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"162d4848-4582-0543-95c8-cd80214035ef"],
 Cell[BoxData[
  RowBox[{"HGBrillLindquist", "[", 
   RowBox[{
    StyleBox["n", "TI"], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["mass1", "TI"], ",", " ", 
      StyleBox["mass2", "TI"]}], "}"}], ",", " ", 
    StyleBox["separation", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9d3403d-b5f0-3645-840b-661380085640"],
 "\[LineSeparator]",
 "generates an ",
 Cell[BoxData[
  FormBox[
   StyleBox["n", "TI"], TraditionalForm]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef7b1483-efa6-8741-848e-54c36dda09d0"],
 "-point Brill-Lindquist two-black-hole initial condition.",
 "\n"
}], "Usage",ExpressionUUID->"6cc2f578-a686-be49-bb92-3a504d902412"],

Cell[TextData[{
 "The result is an initial-condition object: pass it as the second argument \
of ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3558df56-4145-f541-ba68-2a280e409778"],
 ", or convert it to a ",
 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7652be29-2d32-704c-ba26-7ec46c9577b1"],
 " with ",
 Cell[BoxData["HGToGraph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ff85a6a-c017-f649-85ed-c46c81d6be39"],
 "."
}], "Notes",ExpressionUUID->"2e9e1ebe-f274-904b-8bbb-3e6c9021cfc0"]
}, Open  ]],

