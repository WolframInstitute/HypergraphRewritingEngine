Cell[TextData[{
 "The initial-condition generators return an initial-condition object; ",
 Cell[BoxData["HGToGraph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34194b4b-cb1e-b44a-8a11-8d95949df13b"],
 " renders it as a ",
 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ddc51c6-888a-ba4f-bc0a-ca59c1caebab"],
 " for visualization or further processing."
}], "Notes",ExpressionUUID->"cf7adaf9-d0b3-a946-a4ff-954071229d5d"],

Cell[TextData[{
 Cell[BoxData["edges"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed60b328-d8d8-dd4b-bc40-70e316ff55c4"],
 " is a list of hyperedges (each a list of vertices) \[LongDash] the same \
form ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f0ee41e-8d88-dd4b-9914-6cb5b2e8ae53"],
 " takes as its initial state."
}], "Notes",ExpressionUUID->"f611c159-fab6-c448-837b-696ed7806bb7"],

Cell[TextData[{
 "An initial-condition object can also be passed directly as the second \
argument of ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef139f04-6daf-5047-b3ad-97decfd20cda"],
 ", so no explicit conversion is needed to evolve from it."
}], "Notes",ExpressionUUID->"7512ea68-4cd7-994c-96d1-95e540965fea"]
}, Open  ]],

