 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8473f34b-4658-da41-8810-8f7125ca2d8b"],
 " with ",
 Cell[BoxData["HGToGraph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acc89ed5-d388-e746-a5cc-0e18efe3de55"],
