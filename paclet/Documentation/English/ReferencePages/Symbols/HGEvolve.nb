Cell[CellGroupData[{

Cell["\"TargetDevice\"", "ExampleSubsection",ExpressionUUID->"610037ed-ddeb-0742-b02e-acf52bb5549e"],

Cell[TextData[{
 "Evolution runs on the CPU by default. Where a GPU build is bundled, ",
 Cell[BoxData["\"\<GPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62887e01-cd50-8245-a1ca-9dbb286e70ac"],
 " runs on the device; otherwise it falls back to the CPU with a message. The \
GPU engine honors the same ",
 Cell[BoxData["\"\<CanonicalizeStates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f152291a-25a5-7f49-a97b-bb4a74ddd48c"],
 " modes (",
 Cell[BoxData["None"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cbe64d25-ec33-2048-805b-74b576cd3e0f"],
 ", ",
 Cell[BoxData["Automatic"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2339542b-a1f3-4849-bf6a-f48f90fc3033"],
 ", ",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d6ff2a4-e18c-c44d-9e6c-d3b873198384"],
 ") as the CPU, and its state counts match the CPU's in every mode:"
}], "ExampleText",ExpressionUUID->"6605bc9d-eb28-1548-a3ab-ff528037538d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rules", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], "}"}], " ", "->", " ", 
