Cell[TextData[{
 "Each analysis family is gated by a boolean (all ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "498ef5b3-5d3d-b14d-928c-86dc76974467"],
 " by default) and, when enabled, attaches its results to the evolution (see \
also the dedicated ",
 Cell[BoxData["HGHausdorffAnalysis"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee6ce360-c5b6-2d48-9d37-0ebd12a02782"],
 ", ",
 Cell[BoxData["HGGeodesicPlot"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3279d30c-4f0c-3d4d-bcb9-51880fd989d5"],
 ", ",
 Cell[BoxData["HGStateDimensionPlot"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6aa2019-8ca0-f148-8404-ac87839b16a1"],
 ", and related reference pages)."
}], "Notes",ExpressionUUID->"a43aa8ec-363c-0943-b30a-8336a8524a84"],

