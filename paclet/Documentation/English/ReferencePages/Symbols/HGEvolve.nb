Cell[TextData[{
 Cell[BoxData["prop"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e39a1a5f-037e-b843-aa37-8a18bb47b175"],
 " may also be a list of property strings, in which case an association keyed \
by those strings is returned."
}], "Notes",ExpressionUUID->"5841f59b-0d1f-074a-86fa-9e1699757bdf"],

Cell[TextData[{
 "Any ",
 Cell[BoxData[
  RowBox[{"*", "Graph"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32a72c8b-972a-ba4d-82c0-51580bd20632"],
 " property may take the suffix ",
 Cell[BoxData["Structure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96e674e0-d850-bc47-826c-3fc89303ef3d"],
 " to return the same graph without vertex styling (a lighter-weight \
rendering), e.g. ",
 Cell[BoxData["\"\<StatesGraphStructure\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1471b0e-a559-2f42-aaef-bc97e92d705d"],
 "."
}], "Notes",ExpressionUUID->"2b21d330-63a5-b044-9481-35d19a809703"],

Cell[TextData[{
 "A raw ",
 Cell[BoxData["\"\<States\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7887cf5f-acbb-674f-8f53-09239a8fbb80"],
 " result is a list of associations, one per state, with keys ",
 Cell[BoxData["\"\<Id\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef8d7dac-02b5-0d41-a68b-fa26e0d81d5a"],
 ", ",
 Cell[BoxData["\"\<CanonicalId\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bddfb972-63e2-8648-8222-d4c2fbb29733"],
 ", ",
 Cell[BoxData["\"\<Step\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a22290e-6eab-3846-b12b-29c0838541ca"],
 ", ",
 Cell[BoxData["\"\<IsInitial\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72e1da40-ca07-b049-b73f-5e5dac84ab5d"],
 ", ",
 Cell[BoxData["\"\<Edges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5994ab2b-aede-554a-9657-1fb8397e230f"],
 " (the state's hyperedges), and \[LongDash] when ",
 Cell[BoxData[
  RowBox[{"\"\<IncludeCanonicalHashes\>\"", " ", "->", " ", "True"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a56dd03-cf3c-cc42-be74-29855b17a90c"],
 " \[LongDash] ",
 Cell[BoxData["\"\<CanonicalHash\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecf4bf5c-fc02-f04c-b6a3-d3f0fda3e244"],
 ". A raw ",
 Cell[BoxData["\"\<Events\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "901e260b-d4ec-d744-ac57-6fbc6f5c5645"],
 " result is a list of associations with keys ",
 Cell[BoxData["\"\<Id\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "17444b93-2216-af46-adb0-5fa529b053a6"],
 ", ",
 Cell[BoxData["\"\<CanonicalId\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01953ced-768a-ac44-9520-9f19943ad445"],
 ", ",
 Cell[BoxData["\"\<RuleIndex\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6bf0b342-9e90-de44-a11d-9e9197c205df"],
 ", ",
 Cell[BoxData["\"\<Step\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fd157b4a-6fa8-414c-be5f-02be07246b6f"],
 ", ",
 Cell[BoxData["\"\<InputState\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34c099f5-cc5d-734c-a213-09781189f6ef"],
 "/",
 Cell[BoxData["\"\<OutputState\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae0f7a3a-77ec-de42-a39d-51832c638aab"],
 " (state ids), ",
 Cell[BoxData["\"\<ConsumedEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c5a637de-d7b1-384a-818f-db3d9d954b68"],
 "/",
 Cell[BoxData["\"\<ProducedEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01278a3c-5e8e-0f44-ae1f-6db4cb4f43e5"],
 " (edge ids), and ",
 Cell[BoxData["\"\<InputStateEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f70ee3d5-53ff-3540-ac74-a305e70d4a46"],
 "/",
 Cell[BoxData["\"\<OutputStateEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5b91bcc-b2f1-9c42-b852-0d148c899f6a"],
 " (the full edge lists)."
}], "Notes",ExpressionUUID->"61fe1b0e-f1f9-aa4f-b9d7-8bb48569e646"],

Cell["\<\
State and event deduplication, exploration limits, and the output content are \
controlled by:\
\>", "Notes",ExpressionUUID->"9f702f66-668a-c348-84fc-d7f35d651399"],

