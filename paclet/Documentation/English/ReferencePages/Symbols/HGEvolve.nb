Cell[CellGroupData[{

Cell["\"UniformRandom\"", "ExampleSubsection",ExpressionUUID->"15d15b60-cdd7-794f-ab25-90dd665c43c1"],

Cell["\<\
Uniform-random mode applies a random subset of matches per step via reservoir \
sampling, tracing a single stochastic history rather than the full multiway \
system:\
\>", "ExampleText",ExpressionUUID->"7a894516-ac98-6f48-b7dc-4a993078375a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rules", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
