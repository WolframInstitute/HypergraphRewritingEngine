Cell["\"CausalTransitiveReduction\"", "ExampleSubsection",ExpressionUUID->"2b38beb9-7fe6-c542-a1d0-7bc326211eb0"],

Cell["\<\
Transitive reduction removes causal edges implied by longer paths. Off keeps \
every causal relation:\
\>", "ExampleText",ExpressionUUID->"3be0199e-ac32-6f42-83eb-c5d903a5128e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rules", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}], " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "4"}], "}"}]}], "}"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{"HGEvolve", "[", 
  RowBox[{"rules", ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1"}], "}"}]}], "}"}], ",", " ", "2", ",", " ", 
   "\"\<CausalGraphStructure\>\"", ",", " ", 
   RowBox[{"\"\<CausalTransitiveReduction\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
