Cell[TextData[{
 "This rule matches two edges that share a vertex and adds the edge closing \
the triangle between their other two endpoints. By default ",
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "845a70ae-381e-624d-ad6f-e47da1335f07"],
 " returns the combined evolution/causal/branchial graph:"
}], "ExampleText",ExpressionUUID->"30c991a1-dbd7-eb44-813f-626bb7a1dafd"],

