Notebook[{

Cell[CellGroupData[{
Cell["HGEvolve", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"8661fd09-a195-d043-b1ec-83464d54ed19"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["HGEvolve"]], 
     "paclet:WolframInstitute/HypergraphRewriteEngine/ref/HGEvolve", 
     "WolframInstitute/HypergraphRewriteEngine Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["initial", "TI"], ",", " ", 
    StyleBox["steps", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "621d6208-9228-484f-9bbb-096721a364e3"],
 "\[LineSeparator]",
 "performs multiway hypergraph rewriting of the hypergraph ",
 Cell[BoxData["initial"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68e2a00a-5306-954f-be29-4cef76fed97c"],
 " under ",
 Cell[BoxData["rules"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6978a224-1c93-8f40-a238-38a6c7db3f49"],
 " for ",
 Cell[BoxData["steps"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54a8d161-4048-c442-b562-b1a5af47d242"],
 " steps, returning the combined evolution/causal/branchial graph.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"1b594ce9-941c-8a41-a70c-3d73f3036b72"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["HGEvolve"]], 
     "paclet:WolframInstitute/HypergraphRewriteEngine/ref/HGEvolve", 
     "WolframInstitute/HypergraphRewriteEngine Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["initial", "TI"], ",", " ", 
    StyleBox["steps", "TI"], ",", " ", 
    StyleBox["property", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ade64ad-ab61-4b47-86f5-08eb94cbe4bd"],
 "\[LineSeparator]",
 "returns the specified ",
 Cell[BoxData["property"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2eda88d-960a-7d43-bdb4-b52c53d01b0c"],
 "."
}], "Usage",ExpressionUUID->"08922602-af9f-474d-9669-dcf047e61b5f"],

Cell[TextData[{
 "The ",
 StyleBox["rules", "TI"],
 " argument is a rule or list of rules of the form ",
 StyleBox["lhs", "TI"],
 " ",
 Cell[BoxData["->"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7f051b5-d6e7-934e-820f-b466fa53f683"],
 " ",
 StyleBox["rhs", "TI"],
 ", e.g. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}], " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "4"}], "}"}]}], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1b207b0-f14e-8448-83b7-62ae9d5c56ca"],
 ". Each side is a list of hyperedges and each hyperedge is a list of \
vertices. Vertices are variables that bind to (not necessarily distinct) \
vertices of the state hypergraph; a vertex appearing in ",
 StyleBox["rhs", "TI"],
 " but not ",
 StyleBox["lhs", "TI"],
 " is a freshly created vertex."
}], "Notes",ExpressionUUID->"5ebb40ff-b1ab-f844-9ca4-fd7f657b5de1"],

Cell[TextData[{
 "The ",
 StyleBox["initial", "TI"],
 " argument is a single hypergraph state or a list of states given as numeric \
vertex labels, e.g. ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20730d83-fe03-c64e-9c04-8076158c54b5"],
 ". It may also be a ",
 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6647b2eb-cd2f-b243-b884-140bd17b48e9"],
 ", a named initial condition (",
 Cell[BoxData["\"\<Grid\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3238266a-9721-fe48-9989-7c5bc06d57ad"],
 ", ",
 Cell[BoxData["\"\<Sprinkling\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39b1f37c-66ae-e440-b6e3-8bfac7dd17a2"],
 ", \[Ellipsis]), or an initial-condition generator result (",
 Cell[BoxData["HGGrid"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3b245cf5-f688-9041-a0c9-8f72b5d9bda6"],
 ", ",
 Cell[BoxData["HGTorus"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fcbd34c-e45b-714c-bb87-6d51c30088b4"],
 ", \[Ellipsis])."
}], "Notes",ExpressionUUID->"e3eb7309-f798-d045-9cdf-8b9949567953"],

Cell[TextData[{
 "The ",
 StyleBox["steps", "TI"],
 " argument is an integer number of evolution steps."
}], "Notes",ExpressionUUID->"e469bcb2-54c0-ba49-b4f5-054474654077"],

Cell["\<\
The engine applies the rules in all possible ways (multiway evolution), \
optionally deduplicating isomorphic states, and builds the causal and \
branchial graphs. It runs in a standalone process, so a crash or abort never \
affects the notebook.\
\>", "Notes",ExpressionUUID->"4538f21a-4a2a-c644-b5d0-91294bea9684"],

Cell[TextData[{
 "The accepted values for ",
 StyleBox["property", "TI"],
 " include:"
}], "Notes",ExpressionUUID->"f7279ca8-58cc-eb4c-99e9-da806d8ab7bb"],

