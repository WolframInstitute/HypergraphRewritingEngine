Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{3, 5, 6}, {
      Null, {{3, 3}, {2, 3}, {1, 1}, {3, 3}, {2, 3}, {1, 
       1}}, {<|"State1" -> 6, "State2" -> 6|>, <|
        "State1" -> 5, "State2" -> 6|>, <|"State1" -> 3, "State2" -> 3|>, <|
        "State1" -> 6, "State2" -> 6|>, <|"State1" -> 5, "State2" -> 6|>, <|
        "State1" -> 3, "State2" -> 3|>}}, {
      AspectRatio -> None, 
       EdgeLabels -> {
        UndirectedEdge[3, 3, <|"State1" -> 3, "State2" -> 3|>] -> Placed[
           Column[{
             Row[{
               Style["Branchial Edge", Bold]}], 
             
             Grid[{{"State 1:", 3}, {"State 2:", 3}}, Alignment -> Left, 
              Spacings -> {1, 0.5}]}, Spacings -> 0.5], Tooltip], 
         UndirectedEdge[6, 6, <|"State1" -> 6, "State2" -> 6|>] -> Placed[
           Column[{
             Row[{
               Style["Branchial Edge", Bold]}], 
             
             Grid[{{"State 1:", 6}, {"State 2:", 6}}, Alignment -> Left, 
              Spacings -> {1, 0.5}]}, Spacings -> 0.5], Tooltip], 
         UndirectedEdge[5, 6, <|"State1" -> 5, "State2" -> 6|>] -> Placed[
           Column[{
             Row[{
               Style["Branchial Edge", Bold]}], 
             
             Grid[{{"State 1:", 5}, {"State 2:", 6}}, Alignment -> Left, 
              Spacings -> {1, 0.5}]}, Spacings -> 0.5], Tooltip]}, 
       EdgeStyle -> {
        UndirectedEdge[5, 6, <|"State1" -> 5, "State2" -> 6|>] -> 
         Hue[0.89, 0.97, 0.71], 
         UndirectedEdge[6, 6, <|"State1" -> 6, "State2" -> 6|>] -> 
         Hue[0.89, 0.97, 0.71], 
         UndirectedEdge[3, 3, <|"State1" -> 3, "State2" -> 3|>] -> 
         Hue[0.89, 0.97, 0.71]}, Epilog -> {}, GraphLayout -> 
       "LayeredDigraphEmbedding", VertexLabels -> {5 -> Placed[
           Column[{
