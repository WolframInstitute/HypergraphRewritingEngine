Cell[CellGroupData[{

Cell["\"ExploreFromCanonicalStatesOnly\"", "ExampleSubsection",ExpressionUUID->"37cd5bfa-e2a2-b44a-bc2a-a2df3ad72725"],

Cell[TextData[{
 "Quotient exploration expands each canonical state once, at its shortest \
depth, rather than expanding every isomorphic copy \[LongDash] the compact \
way to explore a symmetric system. It is off by default and pairs with ",
 Cell[BoxData[
  RowBox[{"\"\<CanonicalizeStates\>\"", " ", "->", " ", "Full"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "685a6b65-db53-7143-b595-ca64724a586d"],
 ":"
}], "ExampleText",ExpressionUUID->"43d52cde-e718-e746-ba30-7a36759103c0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rules", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}], " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "4"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "4"}], "}"}]}], "}"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{"HGEvolve", "[", 
  RowBox[{"rules", ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1"}], "}"}]}], "}"}], ",", " ", "4", ",", " ", 
   "\"\<StatesGraph\>\"", ",", " ", 
   RowBox[{"\"\<CanonicalizeStates\>\"", " ", "->", " ", "Full"}], ",", " ", 
   RowBox[{
   "\"\<ExploreFromCanonicalStatesOnly\>\"", " ", "->", " ", "True"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"19e0dbfe-5e40-a949-8662-f56e5c62a101"],

