 Cell[BoxData["None"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c0e9c34-536e-c347-b825-741ab45cf995"],
 ", ",
 Cell[BoxData["Automatic"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4d2dcc0-77cc-7347-b7a4-544fe1fcc817"],
 " (fast content hash), or ",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01875e8e-1ab8-6847-8b9c-d4a448fa972a"],
 " (exact isomorphism)."
}], "Item",ExpressionUUID->"f0121ac2-a9d6-3440-9a33-905637474282"],

Cell[TextData[{
 Cell[BoxData["\"\<TargetDevice\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea864664-0000-0e4c-ad00-2e734097d046"],
 " (default ",
 Cell[BoxData["\"\<CPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1e90ec5-b75b-3546-bbfc-e54ec57c6ee1"],
 ") \[LongDash] ",
 Cell[BoxData["\"\<CPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9e9afaa-63d2-2e47-96fb-8673892f29d6"],
 " or ",
 Cell[BoxData["\"\<GPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33d3f4dd-2d0a-8745-b564-05abb9f8e290"],
 ", where a GPU build is bundled."
}], "Item",ExpressionUUID->"3f5d21d2-a602-e847-a5a7-df66a7cc0944"],

Cell[TextData[{
 Cell[BoxData["\"\<CausalTransitiveReduction\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2ebf3ce-da07-0a43-b203-345945975645"],
 " (default ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8bed03f6-aa6f-2b46-a4ba-faa449ca1b43"],
 ") \[LongDash] reduce the causal graph to its transitive reduction."
}], "Item",ExpressionUUID->"44e3349d-832e-8c45-84c7-c3ae7cf97f8f"],

Cell[TextData[{
 Cell[BoxData["\"\<ExploreFromCanonicalStatesOnly\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "87e1cb67-10cd-e64b-9099-53aa5d987601"],
 " (default ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c85ace4-628d-6543-a322-c4d46838caca"],
 ") \[LongDash] quotient exploration: expand each canonical state once at its \
shortest depth."
}], "Item",ExpressionUUID->"b7ce6c81-bec1-804b-a841-ff7a7dd6e5d8"],

Cell[TextData[{
 Cell[BoxData["\"\<IncludeCanonicalHashes\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a13cd89-a843-d346-a15c-e4eb0b0eac8b"],
 " (default ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "226f6a7d-b005-4a4b-92cd-b780b9b6f0f9"],
 ") \[LongDash] attach a run-stable isomorphism hash to each state, for \
fusing results across runs."
}], "Item",ExpressionUUID->"360b5e97-146c-b44d-8199-60b0ba010ee2"],

Cell[TextData[{
 "Use ",
 Cell[BoxData[
  RowBox[{"Options", "[", "HGEvolve", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b645920-ce65-814c-a6e2-4e3b8237c657"],
 " for the full list."
}], "ExampleText",ExpressionUUID->"bab4565d-4091-d94e-854d-5d37e839ca62"]
