Notebook[{

Cell[CellGroupData[{
Cell["HGEvolve", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"9a410a0e-708e-ac43-b1f0-7bbeb120f939"],
 Cell[BoxData[
  RowBox[{"HGEvolve", "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["init", "TI"], ",", " ", 
    StyleBox["steps", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2a02346-27a4-5149-a60a-97679fde5978"],
 "\[LineSeparator]",
 "evolves the hypergraph ",
 Cell[BoxData["init"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2e5077c-ca05-7d4e-ac8e-32efdc28051e"],
 " under ",
 Cell[BoxData["rules"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6a3fc0c-8ef0-b148-a363-e2b82b880e47"],
 " for ",
 Cell[BoxData["steps"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "465d8b73-7a76-9942-a82b-ff42c3b2e3ea"],
 " steps, returning the combined evolution/causal/branchial graph.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"b980598c-438d-4a42-9533-5010224e7d62"],
 Cell[BoxData[
  RowBox[{"HGEvolve", "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["init", "TI"], ",", " ", 
    StyleBox["steps", "TI"], ",", " ", 
    StyleBox["prop", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c67ca6e7-927a-7749-8e8e-f046e2169cc1"],
 "\[LineSeparator]",
 "returns the property ",
 Cell[BoxData["prop"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61d54829-12b3-334f-a1e8-2c1bdbef6050"],
 "."
}], "Usage",ExpressionUUID->"af284420-00d1-7e45-8a90-1439ef25f176"],

Cell[TextData[{
 "Each rule is written ",
 Cell[BoxData[
  RowBox[{"lhs", " ", "->", " ", "rhs"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "263307bd-80af-0549-939c-f0b6069f38f4"],
 ", where each side is a list of hyperedges and each hyperedge is a list of \
vertices. ",
 Cell[BoxData["rules"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d001ebdd-a3b1-7a49-a7fb-63a9fd47d2a3"],
 " may be a single rule or a list of rules."
}], "Notes",ExpressionUUID->"73805469-f901-3a49-8263-9029a9a04b7e"],

Cell[TextData[{
 Cell[BoxData["init"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb87e319-baad-8a42-9c68-dc84221173b5"],
 " is a list of hyperedges, a ",
 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aada1ad2-53ca-f849-91eb-48954f06ed8f"],
 ", a named initial condition (",
 Cell[BoxData["\"\<Grid\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74b3cbb5-b713-124c-b5e7-134283014e3d"],
 ", ",
 Cell[BoxData["\"\<Sprinkling\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27179f99-52b9-5240-819f-6f5f7386f2eb"],
 ", \[Ellipsis]), or an initial-condition generator result (",
 Cell[BoxData["HGGrid"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "092add2e-879b-4941-b5b5-ca1a97d3c4d1"],
 ", ",
 Cell[BoxData["HGTorus"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cc800bc-5220-e24f-b397-f9a34c7c6eb4"],
 ", \[Ellipsis])."
}], "Notes",ExpressionUUID->"7194b97d-43d3-2a46-96d3-99a3ca2dbf8a"],

Cell["\<\
The engine applies the rules in all possible ways (multiway evolution), \
deduplicating isomorphic states, and builds the causal and branchial graphs.\
\>", "Notes",ExpressionUUID->"b2e3faf2-c3ed-7b43-b246-247caeaf3361"],

Cell[TextData[{
 "The property ",
 Cell[BoxData["prop"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bd57a5b-643d-cb48-9348-fede15cc5e51"],
 " is a string or list of strings. Common properties: ",
 Cell[BoxData["\"\<States\>\""], "InlineFormula",
