Cell[TextData[{
 Cell[BoxData["\"\<CanonicalizeStates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5afe6b3a-82ba-2241-a0ae-7d3c942644fe"],
 " (default ",
 Cell[BoxData["None"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "991324cf-b799-f34d-96c6-4cbb752abe2f"],
 ") \[LongDash] state deduplication: ",
 Cell[BoxData["None"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f88401d-100b-824d-bb04-d2cc279cb41c"],
 ", ",
 Cell[BoxData["Automatic"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0cdf2d0b-9d43-f84a-b24c-4e7edd87bc1e"],
 " (fast content hash), or ",
 Cell[BoxData["Full"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "847ac170-892c-7645-bd43-85f6f8039c63"],
 " (exact isomorphism)."
}], "Item",ExpressionUUID->"09c84ed9-5c8b-0d40-b1a6-18f301275fb9"],

Cell[TextData[{
 Cell[BoxData["\"\<TargetDevice\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "439ae23e-3ecb-5849-8877-e22a50164dd7"],
 " (default ",
 Cell[BoxData["\"\<CPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06a62b32-c066-f940-b9ff-f5e848daa31a"],
 ") \[LongDash] ",
 Cell[BoxData["\"\<CPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42eb9dc3-8e07-7e4e-9863-9fd43a6a8c62"],
 " or ",
 Cell[BoxData["\"\<GPU\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1991e855-c575-fc40-82ea-2c1707fbcbf1"],
 ", where a GPU build is bundled."
}], "Item",ExpressionUUID->"b07eaa49-53ae-7247-9aa7-6353d433f393"],

Cell[TextData[{
 Cell[BoxData["\"\<CausalTransitiveReduction\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2d9ff13-7f48-514c-9477-273e846c0f34"],
 " (default ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72bb6a30-41a3-8b4f-a1fe-730b35ce7546"],
 ") \[LongDash] reduce the causal graph to its transitive reduction."
}], "Item",ExpressionUUID->"00b15af0-ef01-d44a-b127-7f48934b1a18"],

Cell[TextData[{
 Cell[BoxData["\"\<ExploreFromCanonicalStatesOnly\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa2a8b34-5022-1640-9fe3-058878a819ed"],
 " (default ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27fd54f4-d398-2941-b342-cd510f530e12"],
 ") \[LongDash] quotient exploration: expand each canonical state once at its \
shortest depth."
}], "Item",ExpressionUUID->"870ef79f-3183-d948-847b-ea8caf08b982"],

Cell[TextData[{
 Cell[BoxData["\"\<IncludeCanonicalHashes\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8e3eb5f-fe2c-7c4b-942d-3e91821bdc61"],
 " (default ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff8cc9b6-2f7d-2449-9daf-402bc1100649"],
 ") \[LongDash] attach a run-stable isomorphism hash to each state, for \
fusing results across runs."
}], "Item",ExpressionUUID->"7325c92a-5d48-bb43-94d5-8ae9e04f3ca0"],

Cell[TextData[{
 "Use ",
