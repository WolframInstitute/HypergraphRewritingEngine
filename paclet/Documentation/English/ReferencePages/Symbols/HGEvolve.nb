  FontSize->0.9 Inherited,ExpressionUUID->
  "42dec447-bbdc-ad41-972c-8f6cfc4cdee1"],
 ", ",
 Cell[BoxData["\"\<StatesGraph\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa421858-871f-3445-9573-05eaaa72b871"],
 ", ",
 Cell[BoxData["\"\<CausalGraph\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a2b336f-89e7-1542-a051-8bc390abeee1"],
 ", ",
 Cell[BoxData["\"\<BranchialGraph\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e2b4aa8-0147-054d-aac1-2024e50d20f2"],
 ", ",
 Cell[BoxData["\"\<EvolutionGraph\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62a7c371-c746-e64e-bf11-5cd65399c44a"],
 ", ",
 Cell[BoxData["\"\<EvolutionCausalBranchialGraph\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4c88042-9ee5-684b-b0b0-4747f33df0d8"],
 " (the default), ",
 Cell[BoxData["\"\<NumStates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f160bcb9-e741-8e4e-a9b7-3bcb6fa7fc9e"],
 ", ",
 Cell[BoxData["\"\<NumEvents\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ee020cd-ea23-7f46-a157-dff721bd5cb7"],
 ", ",
 Cell[BoxData["\"\<CausalEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03cbe2e4-e910-ff4a-ba60-b62c42c7ab9e"],
 ", ",
 Cell[BoxData["\"\<BranchialEdges\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8698118b-c024-dc45-9cf0-27a57b564b25"],
 "."
}], "Notes",ExpressionUUID->"d7edd0d5-475d-b646-9bc1-b8815c656783"],

Cell[TextData[{
 Cell[BoxData["HGEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40eb9d07-680e-d648-8fea-cf07c741c453"],
 " computes in a standalone engine process, so a crash or abort never affects \
the notebook."
}], "Notes",ExpressionUUID->"10bc86f1-049d-7d44-bae6-3b7c95219034"]
