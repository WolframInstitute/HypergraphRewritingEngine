Cell["Cross-run isomorphism hashes", "ExampleSubsection",ExpressionUUID->"67b5dc59-283f-4e47-8b22-dda630aeb0f0"],

Cell[TextData[{
 "Run-local state ids differ between runs, but ",
 Cell[BoxData["\"\<IncludeCanonicalHashes\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "638f2b1e-8cc8-0744-bc30-812c0f48089a"],
 " attaches an isomorphism-stable hash usable to fuse pruned runs by \
isomorphism class:"
}], "ExampleText",ExpressionUUID->"9900ce5c-81bd-de46-93dd-8163a0baf63f"],

