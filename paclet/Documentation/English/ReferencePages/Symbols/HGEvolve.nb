      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "2"}], "}"}]}], "}"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{"HGEvolve", "[", 
  RowBox[{"rules", ",", " ", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], "}"}], ",", " ", "3", ",", " ", 
   "\"\<NumStates\>\"", ",", " ", 
   RowBox[{"\"\<TargetDevice\>\"", " ", "->", " ", "\"\<GPU\>\""}]}], 
  "]"}]}], "Input",
