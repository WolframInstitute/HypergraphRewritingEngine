Cell[CellGroupData[{
Cell["HGEvolve", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"76b6e8ae-05f5-9644-aebb-7b199d4eb6d7"],
 Cell[BoxData[
  RowBox[{"HGEvolve", "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["init", "TI"], ",", " ", 
    StyleBox["steps", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a36e694-6835-e54f-8850-50d946a11db5"],
 "\[LineSeparator]",
 "evolves the hypergraph ",
 Cell[BoxData["init"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79c7945d-7321-7c45-b26b-798c90e92dd8"],
 " under ",
 Cell[BoxData["rules"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9da84bf7-86c2-b044-ae48-37027093742f"],
 " for ",
 Cell[BoxData["steps"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "feb5f532-42f4-9e44-b5dc-cc05485eebe4"],
 " steps, returning the combined evolution/causal/branchial graph.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"5d26a8d5-e561-104f-9ece-3d4086c3a163"],
 Cell[BoxData[
  RowBox[{"HGEvolve", "[", 
   RowBox[{
    StyleBox["rules", "TI"], ",", " ", 
    StyleBox["init", "TI"], ",", " ", 
    StyleBox["steps", "TI"], ",", " ", 
    StyleBox["prop", "TI"]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96d2c164-511a-134e-87e6-17c3e521732e"],
 "\[LineSeparator]",
 "returns the property ",
 Cell[BoxData["prop"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c6d5ce3-cd83-c74a-bcf6-a1cd097b6cc1"],
 "."
}], "Usage",ExpressionUUID->"40024a37-4846-4240-bb0b-eb426b94b88c"],

Cell[TextData[{
 "Each rule is written ",
 Cell[BoxData[
  RowBox[{"lhs", " ", "->", " ", "rhs"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8caabb74-bcd5-f44e-9159-75bcfbbbd739"],
 ", where each side is a list of hyperedges and each hyperedge is a list of \
vertices. ",
 Cell[BoxData["rules"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de9e263c-c7e4-894a-b177-187341916161"],
 " may be a single rule or a list of rules."
}], "Notes",ExpressionUUID->"17f3cb40-3f9d-034a-acc4-f15f78533df1"],

Cell[TextData[{
 Cell[BoxData["init"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "766aacfc-8937-5d40-84a3-dbaca871dbb6"],
 " is a list of hyperedges, a ",
 Cell[BoxData["Graph"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d50c9b1-5c44-0043-85c6-4507a3741469"],
 ", a named initial condition (",
 Cell[BoxData["\"\<Grid\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b11cdc4b-d426-df49-8b87-3a376b1df90b"],
 ", ",
 Cell[BoxData["\"\<Sprinkling\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "073e7307-c5c5-1f4d-8498-28f7a5755381"],
 ", \[Ellipsis]), or an initial-condition generator result (",
 Cell[BoxData["HGGrid"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0792ba8f-efaf-434d-92a7-8e2528993744"],
 ", ",
 Cell[BoxData["HGTorus"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4d12fc9-2f05-b049-8411-fb6d8dd383d2"],
 ", \[Ellipsis])."
}], "Notes",ExpressionUUID->"c32960ee-a7bf-8140-b921-c60e8ccd095f"],

Cell["\<\
The engine applies the rules in all possible ways (multiway evolution), \
deduplicating isomorphic states, and builds the causal and branchial graphs.\
\>", "Notes",ExpressionUUID->"3949933c-366a-1445-b007-72060a89e636"],

