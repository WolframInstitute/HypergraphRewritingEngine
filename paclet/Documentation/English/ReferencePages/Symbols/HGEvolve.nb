Cell[TextData[{
 "Instead of an explicit ",
 StyleBox["initial", "TI"],
 ", an initial condition can be generated in place. The standalone generators \
(",
 Cell[BoxData["HGGrid"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15bf11cf-5646-2046-a81d-0c6105b13b4e"],
 ", ",
 Cell[BoxData["HGMinkowskiSprinkling"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "766d372f-b5df-0f4c-bdca-508c42ccb0a1"],
 ", ",
 Cell[BoxData["HGBrillLindquist"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84e8d92f-b342-b749-b946-accd5ac56b31"],
 ", \[Ellipsis]) are usually clearer, but the same controls are available as \
options:"
}], "Notes",ExpressionUUID->"9047c95e-ccf5-9947-b14a-096d9a72516a"],

