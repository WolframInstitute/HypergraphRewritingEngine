  FontSize->0.9 Inherited,ExpressionUUID->
  "6b41b7c2-c818-5b44-b1fa-3ca8b6180a6e"],
 "."
}], "Notes",ExpressionUUID->"96d4dffe-9e7b-c543-aab4-d64a6008aa36"],

