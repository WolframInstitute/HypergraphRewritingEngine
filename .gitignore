/build*/
/compile_commands.json

# Benchmark results - exclude intermediate files
/benchmark_results/*/*.csv
/benchmark_results/*/per_benchmark/
/benchmark_results/*/benchmark_config.txt

# But keep the markdown and plots
!/benchmark_results/*/BENCHMARKS.md
!/benchmark_results/*/plots/
!/benchmark_results/*/plots/*.png

# Built paclet archives (regenerable via tools/build_paclet.wls / make create_paclet_archive)
*.paclet
/paclet_archive/

# Generated documentation notebooks are BUILD OUTPUT (regenerated + evaluated by
# tools/build_docs.wls); the markdown under Documentation/Source is the committed source
# of truth. Mirrors WolframInstitute/MarkdownToNotebook's own paclets (e.g. AccessibleColors).
/paclet/Documentation/Source/generated/
/paclet/Documentation/English/**/*.nb
# build_docs.sh's transient ext4 landing dir (cp from the Windows-local stage before the
# atomic rename into English/); normally auto-removed, ignored so a crashed run leaves no trace.
/paclet/Documentation/.english_stage/
