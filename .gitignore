/build*/
/compile_commands.json

# Benchmark results - exclude intermediate files
/benchmark_results/*/*.csv
/benchmark_results/*/per_benchmark/
/benchmark_results/*/benchmark_config.txt

# But keep the markdown and plots
!/benchmark_results/*/BENCHMARKS.md
!/benchmark_results/*/plots/
!/benchmark_results/*/plots/*.png

# Built paclet archives (regenerable via tools/build_paclet.wls / make create_paclet_archive)
*.paclet
/paclet_archive/

# Documentation notebooks (Documentation/English/**/*.nb) ARE tracked. They are rendered from the
# markdown (Documentation/Source, the source of truth) by build_docs.sh, but rendering the example
# outputs needs the Wolfram cloud (WolframModelPlot etc.), so they are generated on a cloud-connected
# machine and committed, then assembled into the paclet on any machine.
/paclet/Documentation/Source/generated/
# Transient build_docs scratch (normally auto-removed each run):
/paclet/Documentation/.english_stage/
/paclet/Documentation/English/.build_ok
/paclet/Documentation/English/.doc_manifest.wl
# Stray non-notebook build output under the generated docs tree:
/paclet/Documentation/English/**/*.wl
